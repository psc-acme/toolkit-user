{
    "name": "psc-acme/toolkit-user",
    "description": "Package toolkit-user for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ToolkitUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/event-dispatcher": "^7.0",
        "illuminate/support": "^11.0",
        "brick/date-time": "^0.7.1",
        "symfony/uid": "^7.0"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^7.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}